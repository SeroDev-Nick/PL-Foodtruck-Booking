NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Manager dashboard uses Supabase Auth (email/password).
# Create manager users manually in the Supabase Auth dashboard — there is no signup UI.
# The same URL and anon key above are used for cookie-based sessions.

# SendGrid (server-side only — never prefix these with NEXT_PUBLIC_).
# SENDGRID_FROM_EMAIL must be a verified sender identity in the SendGrid dashboard
# (or an address on an authenticated sending domain) before real delivery will work.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
