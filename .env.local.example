NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Manager dashboard uses Supabase Auth (email/password).
# Create manager users manually in the Supabase Auth dashboard — there is no signup UI.
# The same URL and anon key above are used for cookie-based sessions.

# EmailJS (server-side only — never prefix these with NEXT_PUBLIC_).
# Enable "Allow API for non-browser applications" in EmailJS Account → Security.
# Template variables expected: to_email, business_name, subject, message_body,
# dashboard_url, and optionally message (plain-text summary).
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
